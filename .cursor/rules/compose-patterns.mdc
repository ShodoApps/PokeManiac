## Preview Pattern

### Include Previews in *View.kt or *Preview.kt

```kotlin
@Preview
@Composable
fun MyFeatureViewPreview() {
    PokeManiacTheme {
        MyFeatureView(
            uiState = MyFeatureUiState.Data(
                items = persistentListOf(
                    mockItemUI1,
                    mockItemUI2
                )
            ),
            snackbarHostState = remember { SnackbarHostState() }
        )
    }
}

@Preview
@Composable
fun MyFeatureViewLoadingPreview() {
    PokeManiacTheme {
        MyFeatureView(
            uiState = MyFeatureUiState.Loading,
            snackbarHostState = remember { SnackbarHostState() }
        )
    }
}

@Preview
@Composable
fun MyFeatureViewEmptyPreview() {
    PokeManiacTheme {
        MyFeatureView(
            uiState = MyFeatureUiState.EmptyResult,
            snackbarHostState = remember { SnackbarHostState() }
        )
    }
}
```

