## Testing ViewModels

### Test Template
```kotlin
class MyFeatureViewModelTest {
    private val repository = mockk<MyRepository>()
    private val navigator = mockk<MyNavigator>()
    private val tracking = mockk<TrackingRepository>()
    
    private lateinit var viewModel: MyFeatureViewModel
    
    @Before
    fun setUp() {
        Dispatchers.setMain(UnconfinedTestDispatcher())
        viewModel = MyFeatureViewModel(repository, navigator, tracking)
    }
    
    @After
    fun tearDown() {
        Dispatchers.resetMain()
    }
    
    @Test
    fun `loadData emits Data state with items`() = runTest {
        // Given
        coEvery { repository.fetchItems() } returns listOf(mockItem1, mockItem2)
        
        // When
        viewModel.start()
        
        // Then
        viewModel.uiState.test {
            assert(awaitItem() == Loading)
            assert(awaitItem() is MyFeatureUiState.Data)
        }
    }
}
```

Use **Turbine** for Flow testing:
```kotlin
viewModel.uiState.test {
    assertEquals(Loading, awaitItem())
    assertEquals(Data(...), awaitItem())
}
```
