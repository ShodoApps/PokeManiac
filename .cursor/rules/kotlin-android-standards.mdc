## Coroutines

### ViewModelScope
```kotlin
// ✅ GOOD - use viewModelScope for UI operations
fun loadData() {
    viewModelScope.launch {
        val data = repository.fetchData()
        _state.value = Data(data)
    }
}

// ❌ BAD - manual scope management
GlobalScope.launch { }
CoroutineScope(Dispatchers.Main).launch { }
```

### Error Handling in Coroutines
```kotlin
// ✅ GOOD - try/catch in coroutine
viewModelScope.launch {
    try {
        val data = repository.fetchData()
        _state.value = Data(data)
    } catch (e: Exception) {
        _error.emit(e)
        _state.value = Error
    }
}

// ❌ BAD - unhandled exceptions
viewModelScope.launch {
    val data = repository.fetchData()
}
```

### Flow Collection
```kotlin
// ✅ GOOD - collectLatest for UI events
LaunchedEffect(Unit) {
    viewModel.error.collectLatest { error ->
        snackbarHostState.showSnackbar(error.message.toString())
    }
}

// ✅ GOOD - collect for continuous streams
repository.items.collect { items ->
    _state.value = State.Data(items)
}

// ❌ BAD - collect on GlobalScope
GlobalScope.launch {
    repository.items.collect { ... }
}
```

