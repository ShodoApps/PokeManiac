## Visibility Modifiers

### Principle: Most Restrictive
```kotlin
// ✅ GOOD - private by default
private class MyViewModel(...)
private fun _internalFunction() {}
internal fun _moduleApi() {}
public fun publicApi() {}

// ❌ BAD - over-exposing
public class MyViewModel(...)
public fun _internalFunction() {}
```

### ViewModel Exposure Pattern
```kotlin
// ✅ GOOD - expose only what's needed
class MyViewModel : ViewModel() {
    private val _state = MutableStateFlow<UiState>()
    val state: StateFlow<UiState> = _state.asStateFlow()
    
    private val _error = MutableSharedFlow<Exception>()
    val error: SharedFlow<Exception> = _error.asSharedFlow()
    
    fun onAction() { }  // Public actions
    
    private suspend fun loadData() { }  // Private implementation
}

// ❌ BAD - expose internal details
class MyViewModel : ViewModel() {
    val repository: MyRepository  // Don't expose
    val tracking: TrackingRepository  // Don't expose
    var currentItem: Item? = null  // Use StateFlow
}
```

